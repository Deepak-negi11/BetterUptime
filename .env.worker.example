# ===================================
# WORKER ENVIRONMENT (.env.worker)
# Create this file on each regional droplet
# ===================================

# --- CENTRAL SERVER ---
# IP address of your central droplet (where db/redis/api run)
CENTRAL_IP=your_central_server_ip

# --- DATABASE ---
# Same password as central server
DB_PASSWORD=your_database_password

# --- REDIS ---
# Same password as central server
REDIS_PASSWORD=your_redis_password

# --- REGION IDENTITY ---
# Unique identifier for this worker's region
# Examples: india-mumbai, us-east-1, eu-west-1, singapore, australia-sydney
REGION_ID=india-mumbai

# --- ALERTS (Optional - only if worker sends alerts) ---
SMTP_USER=your_gmail_address
SMTP_PASSWORD=your_google_app_password
SMTP_FROM=your_gmail_address
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
